[
  {
    "$set": {
      "ORIGEN": {
        "$switch": {
          "branches": [
            { "case": { "$eq": ["$ORIGEN", 1] }, "then": "USMER" },
            { "case": { "$eq": ["$ORIGEN", 2] }, "then": "FUERA DE USMER" },
            { "case": { "$eq": ["$ORIGEN", 99] }, "then": "NO ESPECIFICADO" }
          ],
          "default": "$ORIGEN"
        }
      }
    }
  }
]