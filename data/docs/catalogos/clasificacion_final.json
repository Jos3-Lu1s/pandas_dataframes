[
  {
    "$set": {
      "CLASIFICACION_FINAL": {
        "$switch": {
          "branches": [
            {
              "case": { "$eq": ["$CLASIFICACION_FINAL", 1] },
              "then": "CASO DE COVID-19 CONFIRMADO POR ASOCIACIÓN CLÍNICA EPIDEMIOLÓGICA"
            },
            {
              "case": { "$eq": ["$CLASIFICACION_FINAL", 2] },
              "then": "CASO DE COVID-19 CONFIRMADO POR COMITÉ DE DICTAMINACIÓN"
            },
            {
              "case": { "$eq": ["$CLASIFICACION_FINAL", 3] },
              "then": "CASO DE SARS-COV-2 CONFIRMADO"
            },
            {
              "case": { "$eq": ["$CLASIFICACION_FINAL", 4] },
              "then": "INVÁLIDO POR LABORATORIO"
            },
            {
              "case": { "$eq": ["$CLASIFICACION_FINAL", 5] },
              "then": "NO REALIZADO POR LABORATORIO"
            },
            {
              "case": { "$eq": ["$CLASIFICACION_FINAL", 6] },
              "then": "CASO SOSPECHOSO"
            },
            {
              "case": { "$eq": ["$CLASIFICACION_FINAL", 7] },
              "then": "NEGATIVO A SARS-COV-2"
            }
          ],
          "default": "$CLASIFICACION_FINAL"
        }
      }
    }
  }
]