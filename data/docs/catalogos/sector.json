            { "case": { "$eq": ["$SECTOR", 8] }, "then": "PEMEX" },
            { "case": { "$eq": ["$SECTOR", 9] }, "then": "PRIVADA" },
            { "case": { "$eq": ["$SECTOR", 10] }, "then": "SEDENA" },
            { "case": { "$eq": ["$SECTOR", 11] }, "then": "SEMAR" },
            { "case": { "$eq": ["$SECTOR", 12] }, "then": "SSA" },
            { "case": { "$eq": ["$SECTOR", 13] }, "then": "UNIVERSITARIO" },
            { "case": { "$eq": ["$SECTOR", 14] }, "then": "CIJ" },
