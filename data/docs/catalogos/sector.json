            { "case": { "$eq": ["$SECTOR", 2] }, "then": "DIF" },
            { "case": { "$eq": ["$SECTOR", 3] }, "then": "ESTATAL" },
            { "case": { "$eq": ["$SECTOR", 4] }, "then": "IMSS" },
            { "case": { "$eq": ["$SECTOR", 5] }, "then": "IMSS-BIENESTAR" },
            { "case": { "$eq": ["$SECTOR", 6] }, "then": "ISSSTE" },
