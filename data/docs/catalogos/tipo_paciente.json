[
  {
    "$set": {
      "TIPO_PACIENTE": {
        "$switch": {
          "branches": [
            { "case": { "$eq": ["$TIPO_PACIENTE", 1] }, "then": "AMBULATORIO" },
            { "case": { "$eq": ["$TIPO_PACIENTE", 2] }, "then": "HOSPITALIZADO" },
            { "case": { "$eq": ["$TIPO_PACIENTE", 99] }, "then": "NO ESPECIFICADO" }
          ],
          "default": "$TIPO_PACIENTE"
        }
      }
    }
  }
]