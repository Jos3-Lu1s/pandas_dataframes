            { "case": { "$eq": ["$RESULTADO_PCR", 22] }, "then": "CORONA 229E" },
            { "case": { "$eq": ["$RESULTADO_PCR", 23] }, "then": "CORONA OC43" },
            { "case": { "$eq": ["$RESULTADO_PCR", 24] }, "then": "CORONA SARS" },
