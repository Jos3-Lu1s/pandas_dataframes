[
  {
    "$set": {
      "RESULTADO_LAB": {
        "$switch": {
          "branches": [
            { "case": { "$eq": ["$RESULTADO_LAB", 1] }, "then": "POSITIVO A SARS-COV-2" },
            { "case": { "$eq": ["$RESULTADO_LAB", 2] }, "then": "NO POSITIVO A SARS-COV-2" },
            { "case": { "$eq": ["$RESULTADO_LAB", 3] }, "then": "RESULTADO PENDIENTE" },
            { "case": { "$eq": ["$RESULTADO_LAB", 4] }, "then": "RESULTADO NO ADECUADO" },
            { "case": { "$eq": ["$RESULTADO_LAB", 97] }, "then": "NO APLICA (CASO SIN MUESTRA)" }
          ],
          "default": "$RESULTADO_LAB"
        }
      }
    }
  }
]